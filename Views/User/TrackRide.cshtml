@model GoRide.Models.ViewModels.LiveTrackingViewModel

@{
    ViewData["Title"] = "Track Ride";
}

<div class="container-fluid p-0">
    <div class="row g-0">
        <!-- Map Section -->
        <div class="col-lg-8">
             <div class="map-placeholder h-100 position-relative" style="min-height: 85vh; background-color: #e9ecef;">
                <div class="text-center">
                    <i class="bi bi-map-fill fs-1 text-primary"></i>
                    <h3>Tracking Ride @Model.RideId</h3>
                    <p>Driver is on the way...</p>
                </div>
                 <!-- Simulation of driver icon on map -->
                 <div style="position: absolute; top: 40%; left: 50%; transform: translate(-50%, -50%);">
                     <i class="bi bi-car-front-fill fs-1 text-dark p-2 bg-white rounded-circle shadow"></i>
                 </div>
            </div>
        </div>

        <!-- Ride Details Panel -->
        <div class="col-lg-4 bg-white shadow-lg border-start">
            <div class="p-4">
                <div class="alert alert-success d-flex align-items-center" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>
                    <div>@Model.Status - Arriving in <strong>@Model.ETA</strong></div>
                </div>

                <div class="card card-custom mb-4">
                    <div class="card-body">
                        <h5 class="card-title text-muted mb-3">Driver Details</h5>
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-light rounded-circle p-3 me-3 text-secondary">
                                <i class="bi bi-person-fill fs-3"></i>
                            </div>
                            <div>
                                <h5 class="mb-0">@Model.DriverName</h5>
                                <div class="text-warning small">
                                    <i class="bi bi-star-fill"></i> 4.8 Rating
                                </div>
                            </div>
                            <div class="ms-auto">
                                <a href="tel:@Model.DriverPhone" class="btn btn-outline-success rounded-circle p-2">
                                    <i class="bi bi-telephone-fill"></i>
                                </a>
                            </div>
                        </div>
                        <div class="row text-center border-top pt-3">
                            <div class="col-6 border-end">
                                <small class="text-muted d-block">Vehicle</small>
                                <strong>@Model.VehicleNumber</strong>
                            </div>
                            <div class="col-6">
                                <small class="text-muted d-block">OTP</small>
                                <strong>4589</strong>
                            </div>
                        </div>
                    </div>
                </div>

                <h6 class="text-muted mb-3">Trip Progress</h6>
                <div class="d-flex align-items-start mb-3">
                    <div class="d-flex flex-column align-items-center me-3" style="height: 100%;">
                        <i class="bi bi-circle-fill text-success small"></i>
                        <div style="width: 2px; height: 40px; background-color: #ddd;"></div>
                        <i class="bi bi-geo-alt-fill text-danger fs-5"></i>
                    </div>
                    <div>
                        <div class="mb-4">
                            <small class="text-muted">PICKUP</small>
                            <div class="fw-bold">My Location</div>
                        </div>
                        <div>
                            <small class="text-muted">DROP OFF</small>
                            <div class="fw-bold">Central Mall</div>
                        </div>
                    </div>
                </div>

                <div class="d-grid gap-2 mt-5">
                    <button class="btn btn-outline-danger">Cancel Ride</button>
                    <button class="btn btn-secondary">Share Ride Details</button>
                </div>
            </div>
        </div>
    </div>
</div>
