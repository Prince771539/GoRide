@model GoRide.Models.ViewModels.Ride.LiveTrackingVM

@{
    ViewData["Title"] = "Track Ride";
}

<div class="container-fluid h-100">
    <div class="row h-100">
        <!-- Live Map -->
        <div class="col-lg-8 order-lg-2 mb-3">
            <div class="map-container shadow-sm rounded border sticky-top" style="top: 20px; height: 80vh;">
                 <div class="map-marker"><i class="bi bi-car-front-fill"></i></div>
                  <div class="position-absolute top-0 start-50 translate-middle-x mt-3 bg-white px-4 py-2 rounded-pill shadow-sm text-center">
                    <span class="text-muted small text-uppercase">Arriving in</span>
                    <div class="fs-4 fw-bold text-dark">@Model.ETA</div>
                </div>
            </div>
        </div>

        <!-- Ride Details -->
        <div class="col-lg-4 order-lg-1">
            <div class="card card-custom mb-3">
                <div class="card-body">
                    <h5 class="card-title mb-4">Meet your Driver</h5>
                    <div class="d-flex align-items-center mb-4">
                        <div class="avatar-circle bg-dark p-4 fs-3">MD</div>
                        <div class="ms-3">
                            <h5 class="mb-0">@Model.DriverName</h5>
                            <div class="text-warning small">
                                <i class="bi bi-star-fill"></i> 4.9 Rating
                            </div>
                            <div class="text-muted small">@Model.VehicleModel • @Model.VehicleNumber</div>
                        </div>
                        <a href="tel:@Model.DriverPhone" class="btn btn-outline-success btn-sm ms-auto rounded-circle p-2">
                            <i class="bi bi-telephone-fill"></i>
                        </a>
                    </div>
                    
                    <hr />

                    <div class="mb-3">
                        <div class="d-flex align-items-start">
                             <div class="me-3 d-flex flex-column align-items-center" style="height: 50px;">
                                <i class="bi bi-dot fs-3 text-success"></i>
                                <div class="border-start border-2 h-100"></div>
                                <i class="bi bi-geo-alt-fill text-danger"></i>
                            </div>
                            <div class="flex-grow-1">
                                <div class="mb-3">
                                    <small class="text-muted text-uppercase">Current Location</small>
                                    <p class="mb-0 fw-bold">@Model.CurrentLocation</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="alert alert-info d-flex align-items-center border-0 bg-opacity-10">
                        <i class="bi bi-shield-check fs-4 me-3"></i>
                        <div>
                            <small class="d-block fw-bold">Ride Safety</small>
                            <small>Share ride details with trusted contacts</small>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card card-custom">
                <div class="card-body">
                    <h6 class="mb-3">Payment</h6>
                     <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <span class="fs-4 fw-bold">$@Model.Fare</span>
                            <span class="badge bg-secondary ms-2">Cash</span>
                        </div>
                        <button class="btn btn-outline-danger btn-sm">Cancel Ride</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
