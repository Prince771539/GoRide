@model GoRide.Models.ViewModels.UserDashboardViewModel

@{
    ViewData["Title"] = "User Dashboard";
}

<div class="Container py-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2>Welcome back, @Model.UserName!</h2>
            <p class="text-muted">Where do you want to go today?</p>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mb-4">
        <div class="col-md-4 mb-3">
            <div class="card card-custom h-100 bg-primary text-white text-center p-4">
                <div class="mb-3"><i class="bi bi-geo-alt fs-1"></i></div>
                <h4>Book a New Ride</h4>
                <a asp-action="BookRide" class="btn btn-light mt-2 rounded-pill fw-bold">Book Now</a>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card card-custom h-100 p-4 text-center">
                <div class="mb-3 text-info"><i class="bi bi-clock-history fs-1"></i></div>
                <h4>Total Rides</h4>
                <h2 class="display-4 fw-bold">@Model.TotalRides</h2>
            </div>
        </div>
        <div class="col-md-4 mb-3">
            <div class="card card-custom h-100 p-4 text-center">
                <div class="mb-3 text-success"><i class="bi bi-wallet2 fs-1"></i></div>
                <h4>Wallet Balance</h4>
                <h2 class="display-4 fw-bold">$0.00</h2>
            </div>
        </div>
    </div>

    <!-- Recent Rides -->
    <div class="card card-custom p-4">
        <h4 class="mb-3">Recent Rides</h4>
        <div class="table-responsive">
            <table class="table table-hover">
                <thead class="table-light">
                    <tr>
                        <th>Ride ID</th>
                        <th>Date</th>
                        <th>Destination</th>
                        <th>Fare</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var ride in Model.RecentRides)
                    {
                        <tr>
                            <td>@ride.RideId</td>
                            <td>@ride.Date.ToString("MMM dd, yyyy")</td>
                            <td>@ride.DropLocation</td>
                            <td>$@ride.Fare</td>
                            <td><span class="badge bg-success">@ride.Status</span></td>
                            <td><a href="#" class="btn btn-sm btn-outline-primary">Details</a></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="text-end mt-3">
            <a asp-action="RideHistory" class="text-decoration-none">View All History &rarr;</a>
        </div>
    </div>
</div>
