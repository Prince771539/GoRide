@model GoRide.Models.ViewModels.User.UserDashboardStatsVM

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-md-8">
            <h2 class="mb-0">Hello, John!</h2>
            <p class="text-muted">Ready for your next trip?</p>
        </div>
        <div class="col-md-4 text-end">
            <a asp-action="BookRide" class="btn btn-primary btn-lg shadow-sm">
                <i class="bi bi-plus-lg me-2"></i>Book New Ride
            </a>
        </div>
    </div>

    <!-- Stats Row -->
    <div class="row mb-5">
        <div class="col-md-4">
            <div class="card card-custom p-3 bg-white border-0 h-100">
                <div class="d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle text-primary me-3">
                        <i class="bi bi-car-front-fill fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0">Total Rides</h6>
                        <h3 class="mb-0 fw-bold">@Model.TotalRides</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card card-custom p-3 bg-white border-0 h-100">
                <div class="d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 p-3 rounded-circle text-success me-3">
                        <i class="bi bi-wallet2 fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0">Total Spent</h6>
                        <h3 class="mb-0 fw-bold">$@Model.TotalSpent</h3>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card card-custom p-3 bg-white border-0 h-100">
                <div class="d-flex align-items-center">
                    <div class="bg-warning bg-opacity-10 p-3 rounded-circle text-warning me-3">
                        <i class="bi bi-clock-history fs-4"></i>
                    </div>
                    <div>
                        <h6 class="text-muted mb-0">Last Ride Status</h6>
                        <h3 class="mb-0 fw-bold">@Model.LastRideStatus</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Activity Placeholder -->
    <div class="card card-custom border-0 p-4">
        <h5 class="mb-4">Recent Activity</h5>
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="bg-light">
                    <tr>
                        <th>Date</th>
                        <th>Pickup</th>
                        <th>Drop</th>
                        <th>Cost</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>Today, 10:30 AM</td>
                        <td>Home</td>
                        <td>Office</td>
                        <td>$45.00</td>
                        <td><span class="badge bg-success">Completed</span></td>
                    </tr>
                     <tr>
                        <td>Yesterday, 6:15 PM</td>
                        <td>Office</td>
                        <td>Gym</td>
                        <td>$25.00</td>
                        <td><span class="badge bg-success">Completed</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>
