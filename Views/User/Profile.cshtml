@model GoRide.Models.ViewModels.User.ProfileVM

@{
    ViewData["Title"] = "My Profile";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card card-custom border-0 p-5 mt-4">
                <div class="text-center mb-4">
                    <div class="avatar-circle bg-primary fs-1 mx-auto mb-3" style="width: 100px; height: 100px;">
                        @Model.FullName.Substring(0,1)
                    </div>
                    <h3 class="fw-bold">@Model.FullName</h3>
                    <p class="text-muted">Passenger</p>
                </div>

                <form class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-muted small">EMAIL ADDRESS</label>
                        <input type="email" class="form-control" value="@Model.Email" readonly disabled>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small">PHONE NUMBER</label>
                        <input type="text" class="form-control" value="@Model.Phone" readonly disabled>
                    </div>
                    <div class="col-12">
                        <label class="form-label text-muted small">ADDRESS</label>
                        <input type="text" class="form-control" value="@Model.Address" readonly disabled>
                    </div>
                    
                    <div class="col-12 mt-4 text-center">
                         <button type="button" class="btn btn-outline-primary px-4">Edit Profile</button>
                         <button type="button" class="btn btn-outline-danger px-4 ms-2">Change Password</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
