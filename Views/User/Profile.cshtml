@model GoRide.Models.ViewModels.UserProfileViewModel

@{
    ViewData["Title"] = "My Profile";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card card-custom p-4">
                <div class="text-center mb-4 border-bottom pb-4">
                    <div class="bg-secondary rounded-circle d-inline-block p-4 mb-3 text-white">
                        <i class="bi bi-person-fill display-4"></i>
                    </div>
                    <h3>@Model.FullName</h3>
                    <p class="text-muted">Passenger</p>
                </div>
                
                <form>
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label text-muted">Full Name</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control-plaintext fw-bold" readonly value="@Model.FullName" />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label text-muted">Email</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control-plaintext fw-bold" readonly value="@Model.Email" />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label text-muted">Phone</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control-plaintext fw-bold" readonly value="@Model.Phone" />
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label text-muted">Address</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control-plaintext fw-bold" readonly value="@Model.Address" />
                        </div>
                    </div>

                    <div class="text-center mt-4">
                        <button type="button" class="btn btn-outline-primary me-2">Edit Profile</button>
                        <button type="button" class="btn btn-outline-danger">Change Password</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
