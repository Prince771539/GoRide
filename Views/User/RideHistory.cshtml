@model IEnumerable<GoRide.Models.ViewModels.RideViewModel>

@{
    ViewData["Title"] = "Ride History";
}

<div class="container py-4">
    <h2 class="mb-4">Ride History</h2>
    
    <div class="card card-custom p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Ride ID</th>
                        <th>Date & Time</th>
                        <th>Driver</th>
                        <th>Pickup</th>
                        <th>Drop</th>
                        <th>Fare</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="fw-bold text-secondary">#@item.RideId</span></td>
                            <td>@item.Date.ToString("MMM dd, yyyy HH:mm")</td>
                            <td>
                                <div class="d-flex align-items-center">
                                    <div class="bg-light rounded-circle p-1 me-2 text-primary">
                                        <i class="bi bi-person h6 mb-0"></i>
                                    </div>
                                    @item.DriverName
                                </div>
                            </td>
                            <td>@item.PickupLocation</td>
                            <td>@item.DropLocation</td>
                            <td class="fw-bold">$@item.Fare</td>
                            <td>
                                @if(item.Status == "Completed")
                                {
                                    <span class="badge bg-success bg-opacity-10 text-success">@item.Status</span>
                                }
                                else if (item.Status == "Cancelled")
                                {
                                    <span class="badge bg-danger bg-opacity-10 text-danger">@item.Status</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary bg-opacity-10 text-primary">@item.Status</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
