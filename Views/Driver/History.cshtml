@model IEnumerable<GoRide.Models.ViewModels.RideViewModel>

@{
    ViewData["Title"] = "Trip History";
}

<div class="container py-4">
    <h2 class="mb-4">Trip History</h2>
    
    <div class="card card-custom p-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th>Ride ID</th>
                        <th>Date</th>
                        <th>Pickup</th>
                        <th>Drop</th>
                        <th>Fare</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>#@item.RideId</td>
                            <td>@item.Date.ToString("MMM dd, yyyy HH:mm")</td>
                            <td>@item.PickupLocation</td>
                            <td>@item.DropLocation</td>
                            <td class="fw-bold">$@item.Fare</td>
                            <td><span class="badge bg-success">@item.Status</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
