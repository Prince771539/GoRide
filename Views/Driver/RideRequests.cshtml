@model IEnumerable<GoRide.Models.ViewModels.Ride.RideRequestVM>

@{
    ViewData["Title"] = "Ride Requests";
}

<div class="container-fluid">
    <h3 class="mb-4">Incoming Requests</h3>
    
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card card-custom border-0 h-100">
                    <div class="card-header bg-white border-bottom-0 pt-4 px-4 d-flex justify-content-between align-items-center">
                         <span class="badge bg-light text-dark border">@item.DistanceKM km away</span>
                         <span class="fw-bold fs-5">$@item.EstimatedFare</span>
                    </div>
                    <div class="card-body px-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="avatar-circle me-3">@item.PassengerName.Substring(0,1)</div>
                            <div>
                                <h5 class="mb-0">@item.PassengerName</h5>
                                <small class="text-muted"><i class="bi bi-star-fill text-warning"></i> @item.PassengerRating</small>
                            </div>
                        </div>
                        
                        <div class="d-flex flex-column gap-2 mb-4">
                            <div class="d-flex align-items-center">
                                <i class="bi bi-record-circle text-success me-3"></i>
                                <span class="text-truncate">@item.PickupLocation</span>
                            </div>
                            <div class="d-flex align-items-center">
                                <i class="bi bi-geo-alt-fill text-danger me-3"></i>
                                <span class="text-truncate">@item.DropLocation</span>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex">
                            <button class="btn btn-outline-secondary flex-fill">Ignore</button>
                            <a asp-action="ActiveRide" class="btn btn-primary flex-fill">Accept Ride</a>
                        </div>
                    </div>
                    <div class="progress" style="height: 3px;">
                      <div class="progress-bar bg-warning" role="progressbar" style="width: 75%" aria-valuenow="75" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
