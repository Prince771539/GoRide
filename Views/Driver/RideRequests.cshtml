@model IEnumerable<GoRide.Models.ViewModels.RideRequestViewModel>

@{
    ViewData["Title"] = "Ride Requests";
}

<div class="container py-4">
    <h2 class="mb-4">Incoming Requests</h2>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-6 mb-4">
                <div class="card card-custom h-100">
                    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                        <span class="badge bg-warning text-dark">New Request</span>
                        <small class="text-muted">2 mins ago</small>
                    </div>
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-light rounded-circle p-2 me-3">
                                <i class="bi bi-person fs-3"></i>
                            </div>
                            <h5 class="mb-0">@item.PassengerName</h5>
                        </div>
                        
                        <div class="mb-3">
                            <div class="d-flex mb-2">
                                <i class="bi bi-geo-alt-fill text-success me-2"></i>
                                <div>
                                    <small class="text-muted d-block">PICKUP</small>
                                    <strong>@item.PickupLocation</strong>
                                </div>
                            </div>
                            <div class="d-flex">
                                <i class="bi bi-geo-alt-fill text-danger me-2"></i>
                                <div>
                                    <small class="text-muted d-block">DROP OFF</small>
                                    <strong>@item.DropLocation</strong>
                                </div>
                            </div>
                        </div>

                        <div class="d-flex justify-content-between align-items-center bg-light p-3 rounded mb-3">
                            <div class="text-center">
                                <small class="text-muted">Distance</small>
                                <div class="fw-bold">@item.DistanceKM km</div>
                            </div>
                             <div class="text-center">
                                <small class="text-muted">Est. Fare</small>
                                <div class="fw-bold fs-5 text-success">$@item.EstimatedFare</div>
                            </div>
                        </div>

                        <div class="d-grid gap-2 d-md-flex">
                            <button class="btn btn-dark flex-grow-1">Reject</button>
                            <a asp-action="ActiveRide" class="btn btn-success flex-grow-1 fw-bold">Accept Ride</a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
