@model GoRide.Models.ViewModels.Ride.LiveTrackingVM

@{
    ViewData["Title"] = "Active Trip";
}

<div class="container-fluid pb-5">
    <!-- Navigation Header -->
    <div class="bg-dark text-white p-3 rounded-top mb-3 d-flex justify-content-between align-items-center">
        <div>
            <h2 class="mb-0">200m</h2>
            <small>Turn right onto Main Street</small>
        </div>
        <i class="bi bi-arrow-right fs-1"></i>
    </div>

    <div class="row">
        <!-- Map -->
        <div class="col-lg-8 mb-3">
             <div class="map-container shadow-sm border rounded" style="height: 60vh;">
                <div class="map-marker"><i class="bi bi-cursor-fill"></i></div>
            </div>
        </div>

        <!-- Controls -->
        <div class="col-lg-4">
            <div class="card card-custom h-100 p-4">
                <div class="d-flex justify-content-between mb-4">
                    <div>
                        <h5 class="mb-1">@ViewData["PassengerName"]</h5>
                        <div class="text-muted"><i class="bi bi-star-fill text-warning"></i> 4.8</div>
                    </div>
                    <a href="tel:@ViewData["PassengerPhone"]" class="btn btn-success rounded-circle p-3 d-flex align-items-center justify-content-center" style="width:50px; height:50px;">
                        <i class="bi bi-telephone-fill"></i>
                    </a>
                </div>

                <div class="timeline ps-3 border-start ms-2 mb-4">
                    <div class="position-relative mb-4 ps-4">
                        <i class="bi bi-dot position-absolute top-0 start-0 translate-middle-x fs-1 text-success bg-white"></i>
                        <small class="text-muted">PICKUP</small>
                        <p class="mb-0 fw-bold">Tech Park Gate 1</p>
                    </div>
                    <div class="position-relative ps-4">
                        <i class="bi bi-geo-alt-fill position-absolute top-0 start-0 translate-middle-x text-danger bg-white p-1"></i>
                        <small class="text-muted">DROP</small>
                        <p class="mb-0 fw-bold">Metro Station</p>
                    </div>
                </div>

                <div class="mt-auto">
                    <div class="d-grid gap-2">
                        <button class="btn btn-primary btn-lg py-3">
                            <i class="bi bi-geo-alt me-2"></i> Navigate
                        </button>
                        <button class="btn btn-success btn-lg py-3">
                            Complete Ride
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
