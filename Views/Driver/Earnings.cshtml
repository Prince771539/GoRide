@model GoRide.Models.ViewModels.DriverEarningsViewModel

@{
    ViewData["Title"] = "My Earnings";
}

<div class="container py-4">
    <h2 class="mb-4">Earnings Dashboard</h2>
    
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card card-custom bg-success text-white p-4 h-100">
                <h5>Total Earnings</h5>
                <h1 class="display-3 fw-bold">$@Model.TotalEarnings</h1>
                <p class="mb-0">Lifetime earnings with GoRide</p>
            </div>
        </div>
        <div class="col-md-6">
             <div class="card card-custom bg-dark text-white p-4 h-100">
                <h5>This Week</h5>
                <h1 class="display-3 fw-bold">$@Model.WeeklyEarnings</h1>
                <p class="mb-0">Keep it up! You're doing great.</p>
            </div>
        </div>
    </div>

    <!-- Chart Placeholder -->
    <div class="card card-custom p-4 mb-4">
        <h5 class="card-title">Weekly Performance</h5>
        <div style="height: 200px; background-color: #f8f9fa; display: flex; align-items: center; justify-content: center; border-radius: 8px;">
            <p class="text-muted">Interactive Earnings Chart Placeholder</p>
        </div>
    </div>

    <h4 class="mb-3">Recent Transactions</h4>
    <div class="card card-custom border-0">
        <div class="list-group list-group-flush">
            @foreach (var trip in Model.TripHistory)
            {
                <div class="list-group-item d-flex justify-content-between align-items-center py-3">
                    <div>
                        <h6 class="mb-0">Trip #@trip.RideId</h6>
                        <small class="text-muted">@trip.Date.ToString("MMM dd - HH:mm")</small>
                    </div>
                    <div class="text-end">
                        <h5 class="text-success fw-bold mb-0">+$@trip.Fare</h5>
                        <small class="badge bg-light text-dark border">Completed</small>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
