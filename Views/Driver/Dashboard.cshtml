@model GoRide.Models.ViewModels.Driver.DriverDashboardStatsVM

@{
    ViewData["Title"] = "Driver Dashboard";
}

<div class="container-fluid">
    <!-- Status Toggle -->
    <div class="card card-custom border-0 bg-dark text-white mb-4 p-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                 <h2 class="mb-1">You are @(Model.IsOnline ? "Online" : "Offline")</h2>
                 <p class="text-white-50 mb-0">
                    @(Model.IsOnline ? "Waiting for ride requests..." : "Go online to start receiving rides")
                 </p>
            </div>
            <div class="form-check form-switch fs-2">
                <input class="form-check-input" type="checkbox" id="flexSwitchCheckChecked" @(Model.IsOnline ? "checked" : "")>
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card card-custom p-3 border-0 h-100 text-center">
                <h6 class="text-muted">Today's Earnings</h6>
                <h3 class="fw-bold text-success">$@Model.TodayEarnings</h3>
            </div>
        </div>
         <div class="col-md-3">
            <div class="card card-custom p-3 border-0 h-100 text-center">
                <h6 class="text-muted">Trips Completed</h6>
                <h3 class="fw-bold">@Model.TodayTrips</h3>
            </div>
        </div>
         <div class="col-md-3">
            <div class="card card-custom p-3 border-0 h-100 text-center">
                <h6 class="text-muted">Acceptance Rate</h6>
                <h3 class="fw-bold text-primary">95%</h3>
            </div>
        </div>
         <div class="col-md-3">
            <div class="card card-custom p-3 border-0 h-100 text-center">
                <h6 class="text-muted">Driver Rating</h6>
                <h3 class="fw-bold text-warning"><i class="bi bi-star-fill"></i> @Model.Rating</h3>
            </div>
        </div>
    </div>

    <!-- Charts Placeholder -->
    <div class="row">
        <div class="col-lg-8">
            <div class="card card-custom p-4 h-100">
                <h5 class="mb-4">Weekly Performance</h5>
                <div class="d-flex align-items-center justify-content-center bg-light rounded" style="height: 300px;">
                    <span class="text-muted">Chart.js Placeholder</span>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
             <div class="card card-custom p-4 h-100">
                <h5 class="mb-4">Recent Feedback</h5>
                <div class="list-group list-group-flush">
                    <div class="list-group-item px-0">
                        <div class="d-flex justify-content-between">
                            <small class="text-muted">Today</small>
                            <span class="text-warning"><i class="bi bi-star-fill"></i> 5.0</span>
                        </div>
                        <p class="mb-0 small">"Great driving, very polite!"</p>
                    </div>
                    <div class="list-group-item px-0">
                        <div class="d-flex justify-content-between">
                            <small class="text-muted">Yesterday</small>
                            <span class="text-warning"><i class="bi bi-star-fill"></i> 5.0</span>
                        </div>
                        <p class="mb-0 small">"Car was clean and fresh."</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
