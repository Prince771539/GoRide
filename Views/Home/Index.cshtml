@{
    ViewData["Title"] = "Home Page";
}

<!-- Hero Section -->
<div class="hero-section text-center mb-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <h1 class="display-3 fw-bold mb-3">Your Ride, Your Way</h1>
                <p class="lead mb-4 fs-4">Fast, Reliable, and Affordable rides at your doorstep.</p>
                <div class="d-flex justify-content-center gap-3">
                    <a asp-controller="Account" asp-action="UserRegister" class="btn btn-warning btn-lg px-5 fw-bold rounded-pill">
                        Book a Ride
                    </a>
                    <a asp-controller="Account" asp-action="DriverRegister" class="btn btn-outline-light btn-lg px-5 fw-bold rounded-pill">
                        Become a Driver
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Features Section -->
<div class="container mb-5">
    <div class="row g-4 text-center">
        <div class="col-md-4">
            <div class="card card-custom h-100 p-4">
                <div class="text-primary mb-3"><i class="bi bi-geo-alt-fill fs-1"></i></div>
                <h3 class="h4">Live Tracking</h3>
                <p class="text-muted">Track your ride in real-time from booking to destination.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card card-custom h-100 p-4">
                <div class="text-primary mb-3"><i class="bi bi-shield-check fs-1"></i></div>
                <h3 class="h4">Safe & Secure</h3>
                <p class="text-muted">Verified drivers and emergency support for your safety.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card card-custom h-100 p-4">
                <div class="text-primary mb-3"><i class="bi bi-wallet2 fs-1"></i></div>
                <h3 class="h4">Affordable</h3>
                <p class="text-muted">Transparent pricing with no hidden charges.</p>
            </div>
        </div>
    </div>
</div>
