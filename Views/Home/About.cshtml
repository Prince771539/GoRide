@{
    ViewData["Title"] = "About Us";
}

<div class="container py-5">
    <h1 class="display-4 text-center mb-5">About GoRide</h1>
    <div class="row align-items-center">
        <div class="col-md-6 mb-4">
            <img src="https://source.unsplash.com/600x400/?team,corporate" alt="About Us" class="img-fluid rounded shadow-lg" />
        </div>
        <div class="col-md-6">
            <p class="lead">We are committed to revolutionizing urban mobility.</p>
            <p>GoRide connects you with the nearest drivers safely and efficiently. Whether you need a quick bike ride to the metro or a comfortable car for a family trip, we have you covered.</p>
            <ul class="list-unstyled mt-3">
                <li class="mb-2"><i class="bi bi-check-circle-fill text-primary me-2"></i> 24/7 Support</li>
                <li class="mb-2"><i class="bi bi-check-circle-fill text-primary me-2"></i> Verified Drivers</li>
                <li class="mb-2"><i class="bi bi-check-circle-fill text-primary me-2"></i> Best Market Rates</li>
            </ul>
        </div>
    </div>
</div>
