@model IEnumerable<GoRide.Models.ViewModels.UserListViewModel>

@{
    ViewData["Title"] = "Manage Drivers";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Drivers Management</h2>
        <a asp-controller="Account" asp-action="DriverRegister" class="btn btn-warning"><i class="bi bi-plus-lg"></i> Add Driver</a>
    </div>

    <div class="card card-custom p-4">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Joined</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Id</td>
                        <td>
                             <div class="d-flex align-items-center">
                                <div class="bg-light rounded-circle p-1 me-2"><i class="bi bi-person"></i></div>
                                @user.Name
                            </div>
                        </td>
                        <td>@user.Email</td>
                        <td><span class="badge bg-warning text-dark">@user.Role</span></td>
                        <td>@user.JoinDate.ToString("MMM dd, yyyy")</td>
                        <td>
                             @if(user.Status == "Active") {
                                <span class="badge bg-success">Active</span>
                            } else {
                                <span class="badge bg-danger">Blocked</span>
                            }
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-primary me-1"><i class="bi bi-pencil"></i></button>
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
