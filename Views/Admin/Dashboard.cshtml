@model GoRide.Models.ViewModels.AdminDashboardViewModel

@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-md-12">
            <h2>System Overview</h2>
        </div>
    </div>

    <!-- Stats Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card card-custom text-white bg-primary mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title mb-1">Total Users</h6>
                            <h3 class="mb-0">@Model.TotalUsers</h3>
                        </div>
                        <i class="bi bi-people-fill fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-custom text-white bg-success mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title mb-1">Total Revenue</h6>
                            <h3 class="mb-0">$@Model.TotalRevenue</h3>
                        </div>
                        <i class="bi bi-currency-dollar fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-custom text-white bg-warning mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title mb-1">Active Drivers</h6>
                            <h3 class="mb-0">@Model.TotalDrivers</h3>
                        </div>
                        <i class="bi bi-car-front-fill fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-custom text-white bg-info mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title mb-1">Total Rides</h6>
                            <h3 class="mb-0">@Model.TotalRides</h3>
                        </div>
                        <i class="bi bi-signpost-split-fill fs-1 opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8 mb-4">
            <div class="card card-custom h-100 p-4">
                <h5 class="card-title mb-4">Recent Rides</h5>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Ride ID</th>
                                <th>Driver</th>
                                <th>Pickup</th>
                                <th>Drop</th>
                                <th>Fare</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ride in Model.RecentRides)
                            {
                                <tr>
                                    <td>@ride.RideId</td>
                                    <td>@ride.DriverName</td>
                                    <td>@ride.PickupLocation</td>
                                    <td>@ride.DropLocation</td>
                                    <td>$@ride.Fare</td>
                                    <td><span class="badge bg-success">@ride.Status</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card card-custom h-100 p-4">
                <h5 class="card-title mb-4">Quick Links</h5>
                <div class="list-group">
                    <a asp-action="UsersList" class="list-group-item list-group-item-action">Manage Users</a>
                    <a asp-action="DriversList" class="list-group-item list-group-item-action">Manage Drivers</a>
                    <a asp-action="VehicleList" class="list-group-item list-group-item-action">Vehicle Types</a>
                    <a asp-action="FareSettings" class="list-group-item list-group-item-action">Fare Settings</a>
                </div>
            </div>
        </div>
    </div>
</div>
