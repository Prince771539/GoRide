@model GoRide.Models.ViewModels.Admin.AdminStatsVM

@{
    ViewData["Title"] = "Admin Overview";
}

<div class="container-fluid">
    <h2 class="mb-4">System Overview</h2>

    <!-- Stats Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card card-custom p-4 border-0 h-100 bg-primary text-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="mb-1 text-white-50">Total Revenue</h6>
                        <h2 class="mb-0 fw-bold">$@Model.TotalRevenue</h2>
                    </div>
                    <i class="bi bi-graph-up-arrow fs-2 opacity-50"></i>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-custom p-4 border-0 h-100">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Active Rides</h6>
                        <h2 class="mb-0 fw-bold text-success">@Model.ActiveRides</h2>
                    </div>
                    <div class="bg-success bg-opacity-10 p-3 rounded-circle text-success">
                        <i class="bi bi-car-front-fill fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-custom p-4 border-0 h-100">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Total Drivers</h6>
                        <h2 class="mb-0 fw-bold">@Model.TotalDrivers</h2>
                    </div>
                     <div class="bg-warning bg-opacity-10 p-3 rounded-circle text-warning">
                        <i class="bi bi-people-fill fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card card-custom p-4 border-0 h-100">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-muted mb-1">Total Users</h6>
                        <h2 class="mb-0 fw-bold">@Model.TotalUsers</h2>
                    </div>
                     <div class="bg-info bg-opacity-10 p-3 rounded-circle text-info">
                        <i class="bi bi-person-badge-fill fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Tables Row -->
    <div class="row">
        <div class="col-lg-8">
            <div class="card card-custom border-0 p-4 h-100">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="mb-0">Live Ride Monitor</h5>
                    <button class="btn btn-sm btn-outline-primary">View All</button>
                </div>
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="bg-light">
                            <tr>
                                <th>Ride ID</th>
                                <th>Driver</th>
                                <th>Status</th>
                                <th>Current Loc</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td>#R992</td>
                                <td>Mike D.</td>
                                <td><span class="badge bg-primary">In Progress</span></td>
                                <td>5th Avenue</td>
                                <td><button class="btn btn-sm btn-light"><i class="bi bi-eye"></i></button></td>
                            </tr>
                             <tr>
                                <td>#R993</td>
                                <td>Sarah J.</td>
                                <td><span class="badge bg-warning text-dark">Arriving</span></td>
                                <td>Central Park</td>
                                <td><button class="btn btn-sm btn-light"><i class="bi bi-eye"></i></button></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        
        <div class="col-lg-4">
            <div class="card card-custom border-0 p-4 h-100">
                <h5 class="mb-4">System Alerts</h5>
                <div class="d-flex align-items-start mb-3">
                    <i class="bi bi-exclamation-circle-fill text-danger fs-5 me-2"></i>
                    <div>
                        <small class="fw-bold d-block">Surge Pricing Active</small>
                        <small class="text-muted">High demand in Downtown area.</small>
                    </div>
                </div>
                <div class="d-flex align-items-start mb-3">
                    <i class="bi bi-info-circle-fill text-info fs-5 me-2"></i>
                    <div>
                        <small class="fw-bold d-block">New Driver Registrations</small>
                        <small class="text-muted">5 drivers pending approval.</small>
                        <a asp-action="DriversList" class="d-block small mt-1">Review Now</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
