@model GoRide.Models.ViewModels.Admin.SettingsVM

@{
    ViewData["Title"] = "Platform Settings";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h3 class="mb-4">Fare & Platform Settings</h3>
            
            <div class="card card-custom border-0 p-4">
                <form>
                    <h5 class="text-muted mb-4 text-uppercase small fw-bold">General Configuration</h5>
                    
                    <div class="mb-4">
                        <label class="form-label fw-bold">Platform Fee (%)</label>
                        <div class="input-group">
                            <input asp-for="PlatformFeePercentage" class="form-control" type="number" step="0.1">
                            <span class="input-group-text">%</span>
                        </div>
                        <small class="text-muted">Percentage taken from every ride.</small>
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Surge Multiplier</label>
                        <div class="input-group">
                            <span class="input-group-text">x</span>
                             <input asp-for="SurgeMultiplier" class="form-control" type="number" step="0.1">
                        </div>
                         <small class="text-muted">1.0 = Normal Fare. Increase during high demand.</small>
                    </div>

                    <hr class="my-4">

                    <div class="d-flex justify-content-end gap-2">
                        <button type="button" class="btn btn-light">Reset Defaults</button>
                        <button type="submit" class="btn btn-primary px-4">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
