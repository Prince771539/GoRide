@model GoRide.Models.ViewModels.FareSettingsViewModel

@{
    ViewData["Title"] = "Fare Settings";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card card-custom p-4">
                <h3 class="mb-4">Fare Configuration</h3>
                <form>
                    <h5 class="text-secondary border-bottom pb-2 mb-3">Bike Fares</h5>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="BaseFareBike" class="form-label">Base Fare</label>
                            <input asp-for="BaseFareBike" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PerKmBike" class="form-label">Per KM Rate</label>
                            <input asp-for="PerKmBike" class="form-control" />
                        </div>
                    </div>

                    <h5 class="text-secondary border-bottom pb-2 mb-3 mt-4">Car Fares</h5>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="BaseFareCar" class="form-label">Base Fare</label>
                            <input asp-for="BaseFareCar" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="PerKmCar" class="form-label">Per KM Rate</label>
                            <input asp-for="PerKmCar" class="form-control" />
                        </div>
                    </div>

                    <h5 class="text-secondary border-bottom pb-2 mb-3 mt-4">General</h5>
                    <div class="mb-4">
                         <label asp-for="SurgeMultiplier" class="form-label">Surge Multiplier (1.0 = Normal)</label>
                         <input asp-for="SurgeMultiplier" class="form-control" />
                    </div>

                    <button type="submit" class="btn btn-primary px-5">Save Changes</button>
                </form>
            </div>
        </div>
    </div>
</div>
