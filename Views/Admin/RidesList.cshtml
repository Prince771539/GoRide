@model IEnumerable<GoRide.Models.ViewModels.Ride.RideHistoryVM>

@{
    ViewData["Title"] = "Ride History Logs";
}

<div class="container-fluid">
    <h3 class="mb-4">All Ride Transactions</h3>

    <div class="card card-custom border-0 p-4">
        <table class="table table-hover align-middle">
            <thead class="bg-light">
                <tr>
                    <th>Ride ID</th>
                    <th>Date/Time</th>
                    <th>Driver</th>
                    <th>Route</th>
                    <th>Fare</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="fw-bold">@item.RideId</span></td>
                        <td>@item.Date.ToString("g")</td>
                        <td>@item.DriverName</td>
                        <td>
                            <small class="d-block text-muted">FROM: @item.Pickup</small>
                            <small class="d-block text-muted">TO: @item.Drop</small>
                        </td>
                        <td>$@item.Fare</td>
                        <td>
                            <span class="badge bg-success bg-opacity-10 text-success px-2 py-1">@item.Status</span>
                        </td>
                        <td>
                            <button class="btn btn-sm btn-outline-info"><i class="bi bi-info-circle"></i></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
