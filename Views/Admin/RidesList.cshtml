@model IEnumerable<GoRide.Models.ViewModels.RideViewModel>

@{
    ViewData["Title"] = "All Rides";
}

<div class="container py-4">
    <h2 class="mb-4">Rides Management</h2>

    <div class="card card-custom p-4">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Ride ID</th>
                    <th>Date</th>
                    <th>Driver</th>
                    <th>Pickup</th>
                    <th>Drop</th>
                    <th>Fare</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>#@item.RideId</td>
                        <td>@item.Date.ToString("MMM dd, yyyy")</td>
                        <td>@item.DriverName</td>
                        <td>@item.PickupLocation</td>
                        <td>@item.DropLocation</td>
                        <td>$@item.Fare</td>
                        <td>
                            @if(item.Status == "Completed")
                            {
                                <span class="badge bg-success">@item.Status</span>
                            }
                            else if(item.Status == "Cancelled")
                            {
                                <span class="badge bg-danger">@item.Status</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">@item.Status</span>
                            }
                        </td>
                        <td>
                            <button class="btn btn-sm btn-info text-white"><i class="bi bi-eye"></i></button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
